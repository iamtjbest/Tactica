name: Weekly Tactical Data Update

on:
  schedule:
    # This cron schedule tells GitHub to run automatically every day at Midnight (UTC)
    - cron: '0 0 * * *'
  workflow_dispatch: # This just keeps the manual button available just in case

jobs:
  update-stats:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout the repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install requests pandas

      - name: Run the Auto-Updater Script
        env:
          API_SPORTS_KEY: ${{ secrets.API_SPORTS_KEY }}
        run: python auto_updater.py

      - name: Commit and Push the updated JSON files
        run: |
          git config --global user.name "Tactical-AI-Bot"
          git config --global user.email "bot@tacticalai.com"
          git add players.json teams.json
          git diff --quiet && git diff --staged --quiet || (git commit -m "🤖 Auto-updated weekly player stats" && git push)
          
      - name: Run Data Harvester and ML Trainer
        env:
          API_SPORTS_KEY: ${{ secrets.API_SPORTS_KEY }}
        run: |
          python auto_updater.py
          python true_ml_trainer.py
          
      - name: Commit and Push Updates
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@users.noreply.github.com'
          git add players.json teams.json tactical_model.pkl
          git commit -m "🤖 Auto-updated stats and retrained True ML Brain" || echo "No changes to commit"
          git push
